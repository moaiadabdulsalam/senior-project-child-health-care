// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * ----***** ENUMS *****----
 */

enum Role {
  CHILD
  PARENT
  DOCTOR
  ADMIN
}

enum DoctorStatus {
  REJECTED
  VERIFYING
  CONFIRMING
}

enum Gender {
  Male
  Female
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ExceptionType {
  DAY_OFF
  CUSTOM_UNAVAILABLE_HOURS
  CUSTOM_AVAILABLE_HOURS
}

enum Currency {
  USD
  SYR
}

enum AppointmentStatus {
  PENDING
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum MedicineUnit {
  ml
  tablet
  dose
  drop
}

enum GameSessionStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  ABANDONED
}

enum MedicationStatus {
  COMPLETED
  CANCELLED
  ACTIVE
}

enum NotificationType {
  APPOINTMENT_UPDATE_DATE
  APPOINTMENT_REMINDER
  APPOINTMENT_DELETED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  CHILD_LOGIN
  MEDICATION_REMINDER
  DOCTOR_IN_EXCEPTION
  DOCTOR_DAY_IN
  DOCTOR_VERIFIED
  DOCTOR_REJECTED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  CHILD_PROFILE_UPDATED
  SYSTEM_ALERT
}

/**
 * ----***** MODELS *****----
 */

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  passwordHash       String
  role               Role
  isActive           Boolean?       @default(true)
  hashedRefreshToken String?
  profileParent      ProfileParent?
  profileDoctory     ProfileDoctor?

  receivedNotifications Notification[] @relation("NotificationRecipient")
  sentNotifications     Notification[] @relation("NotificationSender")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model ProfileParent {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName       String
  fullNameArabic String?
  phone          String
  address        String?
  addressArabic  String?

  child       Child[]
  appointment Appointment[]
  payment     Payment[]
  medication  Medication[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
}

model ProfileDoctor {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName            String
  fullNameArabic      String?
  speciality          String
  specialityArabic    String?
  description         String?
  phone               String
  clinicPhone         String?
  clinicAddress       String?
  clinicAddressArabic String?
  clinicName          String?
  clinicNameArabic    String?
  status              DoctorStatus

  exception          Exception[]
  appointment        Appointment[]
  payment            Payment[]
  availabilityPolicy AvailabilityPolicy?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId, speciality])
}

model Child {
  id            String        @id @default(uuid())
  parentId      String
  profileParent ProfileParent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  fullName       String
  fullNameArabic String?
  gender         Gender
  birthDate      DateTime
  bloodType      String?
  loginHandle    String
  photo          String?
  isActive       Boolean? @default(true)
  role           Role

  gameSessions GameSession[]
  appointment  Appointment[]
  medication   Medication[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([fullName, parentId])
  @@index([fullName, parentId])
}

model AvailabilityPolicy {
  id            String        @id @default(uuid())
  doctorId      String        @unique
  profileDoctor ProfileDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  weeklyOffDays WeekDay[]
  startWork     DateTime
  endWork       DateTime
  slot          Int
  breakStart    DateTime?
  breakEnd      DateTime?
  sessionPrice  Decimal       @db.Decimal(6, 2)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([slot, startWork, endWork])
}

model Exception {
  id String @id @default(uuid())

  doctorId      String
  profileDoctor ProfileDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  reason    String?
  type      ExceptionType
  startTime DateTime
  endTime   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId, startTime, endTime])
}

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  senderId String?
  sender   User?   @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  type    NotificationType
  data    Json?
  title   String
  message String

  isRead Boolean   @default(false)
  sentAt DateTime  @default(now())
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, senderId])
  @@index([isRead])
}

model Payment {
  id String @id @default(uuid())

  appointmentId String        @unique
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  parentId      String
  profileParent ProfileParent @relation(fields: [parentId], references: [id], onDelete: Cascade)
  doctorId      String
  profileDoctor ProfileDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  amount                Decimal       @db.Decimal(6, 2)
  currency              Currency
  status                PaymentStatus
  stripeSessionId       String?       @unique
  stripePaymentIntentId String?       @unique
  stripeCustomerId      String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([doctorId, appointmentId, parentId])
}

model Appointment {
  id String @id @default(uuid())

  doctorId      String
  profileDoctor ProfileDoctor @relation(fields: [doctorId], references: [id])

  childId String
  child   Child  @relation(fields: [childId], references: [id])

  parentId      String
  profileParent ProfileParent     @relation(fields: [parentId], references: [id])
  reminderSent  Boolean           @default(false)
  payment       Payment?
  status        AppointmentStatus
  date          DateTime
  notes         Json?
  reason        String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([date, reminderSent])
  @@index([doctorId, childId, parentId])
}

model Medication {
  id String @id @default(uuid())

  childId String
  child   Child  @relation(fields: [childId], references: [id], onDelete: Cascade)

  parentId      String
  profileParent ProfileParent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  medicineName       String
  mdeicineNameArabic String?
  medicineUnit       MedicineUnit
  medicineAmount     String
  duration           DateTime
  amountPerDay       Int
  firstDoseTime      DateTime
  firstDoseDate      DateTime
  rememberNotify     Boolean          @default(false)
  status             MedicationStatus
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  medicine           MedicationDose[]

  @@index([firstDoseDate, firstDoseTime])
  @@index([medicineName, childId])
}

model MedicationDose {
  id           String     @id @default(uuid())
  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  scheduledAt  DateTime
  reminderSent Boolean  @default(false)
  taken        Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([medicationId, scheduledAt])
  @@index([scheduledAt, medicationId])
}

model Game {
  id              String   @id @default(uuid())
  title           String
  description     String?
  category        String
  minAge          Int?
  maxAge          Int?
  difficultyLevel Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  gameSessions GameSession[]

  @@unique([title])
  @@index([title, category])
}

model GameSession {
  id              String            @id @default(uuid())
  childId         String
  child           Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  gameId          String
  game            Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  startedAt       DateTime          @default(now())
  endedAt         DateTime
  durationSeconds Int?
  score           Int?
  levelReached    Int?
  status          GameSessionStatus @default(IN_PROGRESS)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([childId, gameId])
}
